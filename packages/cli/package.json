{
  "name": "@mindees/cli",
  "version": "0.22.4",
  "description": "MindeesNative Forge — the `mindees` CLI: create, build (via the compiler), dev (rebuild orchestrator), doctor, info.",
  "license": "MIT OR Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "bin": {
    "mindees": "./dist/bin.js"
  },
  "files": [
    "dist",
    "assets"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mindees/mindees.git",
    "directory": "packages/cli"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "gen:android-template": "node scripts/gen-android-template.mjs",
    "check:android-template": "node scripts/gen-android-template.mjs && git diff --exit-code src/android-template.generated.ts"
  },
  "dependencies": {
    "@mindees/core": "workspace:*",
    "@mindees/compiler": "workspace:*",
    "@mindees/ai": "workspace:*"
  }
}
