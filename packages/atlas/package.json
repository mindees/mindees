{
  "name": "@mindees/atlas",
  "version": "0.0.0",
  "description": "MindeesNative Atlas - accessible, signals-native UI primitives + a virtualized recycling list. Renderer-agnostic (web real, native research track).",
  "license": "MIT OR Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./theme": {
      "types": "./dist/theme.d.ts",
      "import": "./dist/theme.js"
    },
    "./list": {
      "types": "./dist/list.d.ts",
      "import": "./dist/list.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mindees/mindees.git",
    "directory": "packages/atlas"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mindees/core": "workspace:*"
  },
  "peerDependencies": {
    "@mindees/renderer": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@mindees/renderer": {
      "optional": true
    }
  },
  "devDependencies": {
    "@mindees/renderer": "workspace:*",
    "happy-dom": "20.9.0"
  }
}
