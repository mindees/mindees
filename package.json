{
  "name": "mindees-native",
  "version": "0.0.0",
  "private": true,
  "description": "MindeesNative — a next-generation cross-platform app framework (monorepo).",
  "license": "MIT OR Apache-2.0",
  "type": "module",
  "homepage": "https://github.com/mindees/mindees",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mindees/mindees.git"
  },
  "bugs": {
    "url": "https://github.com/mindees/mindees/issues"
  },
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=22.18.0",
    "pnpm": ">=11"
  },
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:cli": "node scripts/smoke-cli.mjs",
    "verify": "pnpm run lint && pnpm run typecheck && pnpm run build && pnpm run check:exports && pnpm run smoke:cli && pnpm run test",
    "changeset": "changeset",
    "version-packages": "changeset version && node scripts/sync-versions.mjs",
    "check:versions": "node scripts/sync-versions.mjs --check",
    "check:exports": "node scripts/validate-exports.mjs",
    "release": "node scripts/sync-versions.mjs --check --assert-released && pnpm run build && pnpm run check:exports && changeset publish",
    "prepare": "lefthook install || exit 0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@changesets/cli": "2.31.0",
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "4.1.7",
    "expect-type": "1.3.0",
    "lefthook": "2.1.9",
    "tsdown": "0.22.1",
    "turbo": "2.9.16",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  }
}
